# ─────────────────────────────────────────────
#  PhotoTouch — variables d'environnement
#  Copie ce fichier en .env.local et remplis les valeurs.
# ─────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Limite de générations pendant l'essai gratuit (contrôle des coûts)
NEXT_PUBLIC_TRIAL_GENERATION_LIMIT=5

# ── Supabase (auth · DB · storage) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role — SERVEUR UNIQUEMENT, ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (essai 7 jours via le code, pas le dashboard) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_LIFETIME=

# ── Génération d'image (OpenAI) ──
# Modèle : gpt-image-1 (défaut) ou gpt-image-1-mini (moins cher).
OPENAI_IMAGE_MODEL=
# Qualité : low (défaut, le moins cher) / medium / high.
OPENAI_IMAGE_QUALITY=

# ── Modération ──
# OpenAI Moderation API (prompts)
OPENAI_API_KEY=
# Google Cloud Vision SafeSearch (images) — chemin vers le JSON du service account
GOOGLE_APPLICATION_CREDENTIALS=
# (alternative REST : clé API simple)
GOOGLE_CLOUD_VISION_API_KEY=

# ── Emails (Resend) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL="PhotoTouch <hello@phototouch.app>"

# ── Analytics (PostHog) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Cron (rappels d'essai J-3 / J-1) ──
CRON_SECRET=
